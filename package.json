{
  "name": "avenire",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "prebuild": "bun packages/ai/skills/scripts/generator.ts",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "turbo run format",
    "db:generate": "pnpm --filter @avenire/database db:generate",
    "db:migrate": "pnpm --filter @avenire/database db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "turbo": "latest",
    "typescript": "5.9.3",
    "ultracite": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.12",
      "axios": "1.13.6",
      "effect": "3.20.0",
      "hono": "4.12.9",
      "picomatch": "4.0.4"
    }
  }
}
