{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "extends": ["ultracite"],
  "linter": {
    "rules": {
      "suspicious": {
        "noConsole": "off",
        "noExplicitAny": "off"
      },
      "correctness": {
        "noUnusedImports": "off",
        "noUnusedFunctionParameters": "off",
        "noUnusedLabels": "off",
        "noUnusedPrivateClassMembers": "off",
        "noUnusedVariables": "off"
      },
      "style": {
        "useImportType": "off"
      }
    }
  },
  "files": {
    "ignore": [
      "packages/ui/components/**",
      "packages/ui/lib/**",
      "packages/ui/hooks/**"
    ]
  }
}
