{
  "name": "@avenire/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c 'tsx watch src/server.ts & tsx watch src/ingestion-worker.ts & wait'",
    "dev:ingestion": "tsx watch src/ingestion-worker.ts",
    "build": "tsc --noEmit",
    "start": "sh -c 'tsx src/server.ts & tsx src/ingestion-worker.ts & wait'",
    "start:ingestion": "tsx src/ingestion-worker.ts",
    "lint": "biome check .",
    "check-types": "tsc --noEmit",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@avenire/database": "workspace:*",
    "@avenire/ingestion": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "hono": "^4.8.3",
    "dotenv": "latest",
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@avenire/env-types": "workspace:*",
    "@avenire/typescript-config": "workspace:*",
    "@types/node": "25.3.5",
    "typescript": "5.9.3"
  }
}
