{
  "name": "@avenire/extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:chrome",
    "build:chrome": "node ./scripts/build.mjs --target=chrome",
    "build:firefox": "node ./scripts/build.mjs --target=firefox",
    "dev": "pnpm run dev:chrome",
    "dev:chrome": "node ./scripts/build.mjs --target=chrome --watch",
    "dev:firefox": "node ./scripts/build.mjs --target=firefox --watch",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "defuddle": "^0.15.0",
    "esbuild": "^0.27.5"
  }
}
